{
  "name": "@brachkow/hono-inertia",
  "version": "0.1.0",
  "description": "Inertia.js v3 server-side adapter for Hono",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "author": "brachkow",
  "repository": {
    "type": "git",
    "url": "https://github.com/brachkow/hono-inertia.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "tsup",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "hono": "^4.12.8",
    "np": "^11.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT",
  "keywords": [
    "hono",
    "inertia",
    "inertiajs",
    "adapter",
    "middleware"
  ]
}
